# Frontend (Vite dev server → local backend)
VITE_API_URL=http://localhost:8080/api/v1

# Backend — required, no baked-in default (12-factor; app fails fast if unset)
# 32+ characters; generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-32+-char-random-secret

# docker-compose only
DB_USER=lending
DB_PASSWORD=change-me-too
