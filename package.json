{
  "name": "lending-library-react-ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.23.0",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0",
    "sirv": "^3.0.2",
    "web-vitals": "^3.3.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/node": "^20.6.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react-swc": "^3.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "cross-env": "^10.1.0",
    "jsdom": "^22.0.0",
    "puppeteer": "^24.31.0",
    "serve": "^14.2.5",
    "typescript": "^4.9.5",
    "vite": "^5.1.0",
    "vite-tsconfig-paths": "^4.0.0",
    "vitest": "^1.3.0"
  },
  "scripts": {
    "dev": "node server.js",
    "start": "cross-env NODE_ENV=production node server.js",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --outDir dist/server --ssr src/entry-server.tsx",
    "preview": "vite preview",
    "test": "vitest --coverage",
    "perf:lighthouse": "lhci autorun",
    "perf:cdp": "node scripts/perf-audit.mjs",
    "perf:mcp": "node scripts/mcp-perf-audit.mjs",
    "perf:validate": "npm run build && npm run perf:lighthouse && npm run perf:cdp"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}